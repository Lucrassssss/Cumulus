{
  "mcpServers": {
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp?project_ref=xyzrvgbdnevllwvxqcka"
    },
    "resend": {
      "command": "npx",
      "args": ["-y", "@resend/mcp"],
      "env": {
        "RESEND_API_KEY": "YOUR_RESEND_API_KEY"
      }
    },
    "vercel": {
      "command": "npx",
      "args": ["-y", "@vercel/mcp"],
      "env": {
        "VERCEL_TOKEN": "YOUR_VERCEL_TOKEN"
      }
    }
  }
}
