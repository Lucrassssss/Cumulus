# ══════════════════════════════════════════════════════════════════════════
#  Cumulus — environment template
#
#  1. Copy this file:            cp .env.example .env
#  2. Fill in your real values (see notes below)
#  3. Generate the runtime env:  node scripts/build-env.mjs
#     → writes src/js/env.js (gitignored) which the app loads at startup
#
#  SECURITY NOTES
#  ─ The Supabase anon key and Mapbox pk.* token are *publishable* — they are
#    designed to ship to browsers. Real protection comes from:
#      • Supabase Row Level Security (RLS) policies on every table
#      • Mapbox token URL restrictions (Account → Tokens → URL restrictions)
#  ─ They still do NOT belong in source control: rotating a leaked key must
#    not require a code change, and repo history is forever.
#  ─ If a key was ever committed, ROTATE it (Supabase: Settings → API →
#    "Roll" anon key. Mapbox: create a new token, delete the old one).
# ══════════════════════════════════════════════════════════════════════════

# Supabase project URL (Settings → API → Project URL)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (Settings → API → anon public)
SUPABASE_ANON_KEY=your-anon-key-here

# Mapbox public access token, pk.* (account.mapbox.com → Tokens)
MAPBOX_ACCESS_TOKEN=pk.your-token-here
